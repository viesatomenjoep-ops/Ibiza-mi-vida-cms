# ============================================================
#  Ibiza Mi Vida — Environment Variables Template
#  Copy this file to .env and fill in your values
#  NEVER commit .env to Git — it is in .gitignore
# ============================================================

# ── Supabase (required) ───────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://qqstpsvalgdbjacdkmmk.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Cloudinary (for media uploads) ───────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_PRESET=ibizamivida_uploads

# ── GitHub (for auto-deploy webhook) ─────────────────────
GITHUB_REPO=viesatomenjoep-ops/Ibiza-mi-vida-cms
GITHUB_BRANCH=main
GITHUB_TOKEN=ghp_your_personal_access_token

# ── Docker Hub (for CI/CD image push) ────────────────────
DOCKER_HUB_USERNAME=viesaautomations
DOCKER_HUB_TOKEN=your_dockerhub_access_token
DOCKER_IMAGE_NAME=viesaautomations/ibiza-cms

# ── WhatsApp (lead capture) ───────────────────────────────
WHATSAPP_NUMBER=+34600000000
WHATSAPP_TEMPLATE=Hi! I am interested in: {event_name}

# ── Domain config ─────────────────────────────────────────
DOMAIN_COM=ibizamivida.com
DOMAIN_ES=ibizamivida.es

# ── Local Postgres (dev only — not used in production) ────
POSTGRES_DB=ibizamivida
POSTGRES_USER=ibiza
POSTGRES_PASSWORD=change_me_locally

# ── App ───────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
